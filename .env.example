# ── Stripe ──────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys (test mode first!)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# From `stripe listen --forward-to localhost:3001/api/webhook` (local)
# or your production webhook endpoint's signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── App URLs ────────────────────────────────────────────────────────
# Frontend URL — used for Stripe redirect URLs and CORS allowlist
CLIENT_URL=http://localhost:5173

# Set only for SPLIT deployments (frontend and backend on different
# domains). Leave unset for single-service deploys or local dev.
# VITE_API_URL=https://api.mmine.co

# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
